# ---------------------------------------------------------------------------
# Cursor self-hosted worker identity
# ---------------------------------------------------------------------------

# Must be a Cursor service account API key. User/personal/team/org keys do not
# work for pool workers.
CURSOR_API_KEY=replace-with-service-account-api-key

# Base pool name. Approach-specific configs can prefix this, for example ECS can
# use ecs-lab while EC2 can use lab.
CURSOR_WORKER_POOL_NAME=lab
CURSOR_WORKER_IDLE_RELEASE_TIMEOUT=600

# Shared secret name used by AWS/Kubernetes helpers unless overridden.
CURSOR_API_KEY_SECRET_NAME=my-workers-api-key

# ---------------------------------------------------------------------------
# Worker runtime and labels
# ---------------------------------------------------------------------------

CURSOR_WORKER_LABELS_FILE=/etc/cursor/labels.json

# Defaults to the local git remote origin when empty. ECS/Fargate and EC2 use
# this to initialize a git workspace so Cursor can derive the repo label.
WORKER_REPOSITORY_URL=

# ---------------------------------------------------------------------------
# Local Docker image
# ---------------------------------------------------------------------------

WORKER_IMAGE=cursor-self-hosted-worker:local

# ---------------------------------------------------------------------------
# AWS shared defaults
# ---------------------------------------------------------------------------

AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY_NAME=cursor-self-hosted-worker

# ---------------------------------------------------------------------------
# EC2 + Docker approach
# ---------------------------------------------------------------------------

EC2_INSTANCE_TYPE=t3.small
EC2_WORKER_HOST_NAME=cursor-worker-lab

# ---------------------------------------------------------------------------
# ECS/Fargate approach
# ---------------------------------------------------------------------------

ECS_CLUSTER_NAME=cursor-agents-lab
ECS_SERVICE_NAME=cursor-worker-service
ECS_TASK_FAMILY=cursor-self-hosted-worker

# Start with one worker, keep one idle worker when demand appears, and cap at
# five workers for this lab.
ECS_MIN_CAPACITY=1
ECS_MAX_CAPACITY=5
ECS_TARGET_IDLE_WORKERS=1

# ---------------------------------------------------------------------------
# EKS approach
# ---------------------------------------------------------------------------

# Use an EKS-specific pool name, such as acme-eks-worker-pool.
EKS_CLUSTER_NAME=cursor-agents-lab

# ---------------------------------------------------------------------------
# EKS / Helm worker deployment
# ---------------------------------------------------------------------------

K8S_NAMESPACE=cursord
K8S_WORKER_IMAGE=cursor-self-hosted-worker:local
K8S_WORKER_LABELS_FILE=eks/helm/labels.json
K8S_WORKER_LABELS_CONFIG_MAP=cursor-worker-labels
WORKER_DEPLOYMENT_NAME=my-workers
WORKER_READY_REPLICAS=2
CURSOR_CONTROLLER_RELEASE_NAME=worker-set-controller
CURSOR_CONTROLLER_CHART=oci://public.ecr.aws/j6w0t2f5/cursor/worker-set-controller-chart
CURSOR_CONTROLLER_CHART_VERSION=0.1.0-6c804a0

# ---------------------------------------------------------------------------
# EKS / Helm autoscaling add-ons
# ---------------------------------------------------------------------------

WORKER_MIN_REPLICAS=2
WORKER_MAX_REPLICAS=5
WORKER_TARGET_UTILIZATION_PERCENT=75
K8S_WORKER_METRICS_SERVICE_NAME=cursor-worker-metrics
WORKER_AUTOSCALER_NAME=cursor-worker-metrics-scaler
WORKER_AUTOSCALER_SCHEDULE=* * * * *
WORKER_AUTOSCALER_PROMETHEUS_SERVER_ADDRESS=http://prometheus-server.prometheus.svc.cluster.local
PROMETHEUS_NAMESPACE=prometheus
PROMETHEUS_RELEASE_NAME=prometheus
