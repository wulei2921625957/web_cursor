{
  "name": "coding-agent-cli",
  "version": "0.1.0",
  "description": "A Cursor SDK-powered coding agent CLI with interactive TUI and context compaction.",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "code-agent": "./dist/index.js",
    "code-agent-ui": "./dist/ui.js"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:ui": "bun src/ui.ts",
    "build": "tsc -p tsconfig.json",
    "package:portable": "npm run build && node scripts/package-portable.mjs",
    "prepack": "npm run build",
    "start": "bun dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.7",
    "@opentui/core": "^0.2.0",
    "@opentui/react": "^0.2.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
