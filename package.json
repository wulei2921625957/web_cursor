{
  "name": "coding-agent-web-ui",
  "version": "0.1.0",
  "description": "A Cursor SDK-powered coding agent web UI with context compaction.",
  "private": false,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.13 <27"
  },
  "files": [
    "dist",
    "coding-agent.config.example.json",
    "coding-agent.extensions.example.json",
    "README.md",
    "package.json"
  ],
  "bin": {
    "code-agent-ui": "./dist/ui.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/ui.ts --dev-reload",
    "dev:once": "tsx src/ui.ts",
    "dev:ui": "npm run dev --",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/ui.js",
    "test": "npm run test:unit",
    "test:integration": "tsx --test test/**/*.test.ts",
    "test:unit": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.22",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
