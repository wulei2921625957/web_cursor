{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  },
  "plugins": [".coding-agent/plugins/example-plugin"],
  "hooks": {
    "PreRun": [
      {
        "command": "npm run typecheck",
        "windowsCommand": "npm run typecheck",
        "timeout": 120,
        "statusMessage": "Running project typecheck before agent work"
      }
    ],
    "PostRun": [
      {
        "command": "git status --short",
        "windowsCommand": "git status --short",
        "timeout": 30,
        "statusMessage": "Collecting Git status after agent work"
      }
    ]
  }
}
